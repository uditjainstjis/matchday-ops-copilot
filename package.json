{
  "name": "matchday-ops-copilot",
  "version": "1.0.0",
  "private": true,
  "description": "AI incident-triage copilot for FIFA World Cup 2026 stadium and tournament operations centres.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@eslint/js": "^9.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
