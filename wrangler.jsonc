{
  // Cloudflare Workers configuration.
  // Docs: https://developers.cloudflare.com/workers/wrangler/configuration/
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "matchday-ops-copilot",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-15",

  // Workers AI binding. No API keys are stored anywhere in this repo: the
  // platform injects the `AI` binding at runtime, which is why there is no
  // `.env` file and nothing secret to leak.
  "ai": {
    "binding": "AI"
  },

  // Static frontend.
  //
  // CSS and JS are served straight from Cloudflare's edge cache without ever
  // invoking the Worker -- fewer invocations, lower latency, smaller dynamic
  // attack surface.
  //
  // The HTML document is the one exception: `run_worker_first` routes it
  // through the Worker so that `withSecurityHeaders` can attach the
  // Content-Security-Policy. CSP is a document-level header, so this buys the
  // full security benefit at the cost of exactly one Worker invocation per page
  // load, rather than one per asset.
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/", "/index.html"]
  },

  "observability": {
    "enabled": true
  }
}
